{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.org/cpcs/video-observation-record/1.0",
  "title": "CPCS Video Observation Record",
  "description": "A line-oriented, evidence-aware observation emitted by a deterministic extractor, detector, multimodal model, reviewer, or authoring process.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_id",
    "source_id",
    "time_range",
    "clock",
    "layer",
    "claim",
    "evidence_class",
    "confidence",
    "extractor",
    "evidence"
  ],
  "properties": {
    "record_id": {"type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "source_id": {"type": "string", "minLength": 1},
    "time_range": {"$ref": "#/$defs/timeRange"},
    "clock": {"type": "string", "enum": ["source_pts", "source_seconds", "proxy_pts", "audio_samples", "frame_index", "unknown"]},
    "layer": {
      "type": "string",
      "enum": [
        "media", "shot", "scene", "beat", "actor", "object", "face", "facs", "gaze", "affect",
        "body_pose", "body_mesh", "root_motion", "laban", "action", "phase", "contact", "dynamics",
        "camera", "lens", "framing", "editing", "audio", "speech", "music", "vfx", "marketing",
        "rights", "quality", "other"
      ]
    },
    "claim": {"$ref": "#/$defs/claim"},
    "evidence_class": {"type": "string", "enum": ["measured", "detected", "inferred", "interpreted", "authored"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "confidence_semantics": {"type": ["string", "null"], "description": "Tool-specific meaning; not assumed calibrated across extractors."},
    "extractor": {"$ref": "#/$defs/extractor"},
    "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidenceLocator"}, "minItems": 1},
    "entity_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "segment_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "parent_record_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "alternatives": {"type": "array", "items": {"$ref": "#/$defs/alternative"}},
    "quality_flags": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "rights_tags": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "notes": {"type": ["string", "null"]},
    "created_at": {"type": ["string", "null"], "format": "date-time"}
  },
  "$defs": {
    "timeRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_s", "end_s"],
      "properties": {
        "start_s": {"type": "number", "minimum": 0},
        "end_s": {"type": "number", "minimum": 0},
        "start_frame": {"type": ["integer", "null"], "minimum": 0},
        "end_frame": {"type": ["integer", "null"], "minimum": 0},
        "tolerance_s": {"type": ["number", "null"], "minimum": 0}
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "value"],
      "properties": {
        "type": {"type": "string", "minLength": 1},
        "value": {},
        "units": {"type": ["string", "null"]},
        "coordinate_system": {"type": ["string", "null"]},
        "target_ref": {"type": ["string", "null"]},
        "vocabulary": {"type": ["string", "null"]}
      }
    },
    "extractor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "provider": {"type": ["string", "null"]},
        "model": {"type": ["string", "null"]},
        "api_version": {"type": ["string", "null"]},
        "verified_on": {"type": ["string", "null"], "format": "date"},
        "parameters_digest": {"type": ["string", "null"]},
        "parameters": {"type": ["object", "null"]},
        "sampling": {"type": ["object", "null"]}
      }
    },
    "evidenceLocator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset", "locator"],
      "properties": {
        "asset": {"type": "string", "minLength": 1},
        "locator": {"type": "string", "minLength": 1},
        "sha256": {"type": ["string", "null"], "pattern": "^[a-fA-F0-9]{64}$"},
        "preview_uri": {"type": ["string", "null"]},
        "description": {"type": ["string", "null"]}
      }
    },
    "alternative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "confidence"],
      "properties": {
        "claim": {"$ref": "#/$defs/claim"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "reason": {"type": ["string", "null"]}
      }
    }
  }
}
